# If you deploying via docker compose you don't need to update these values:
# - POSTGRES_HOST
# - POSTGRES_PORT
# - REDIS_HOST
# - REDIS_PORT

# should be 'off' in prod
DEBUG=on

# options:
# - dev (for local development)
# - prod (for deployed versions)
ENVIRONMENT=dev

# Container role for the shared deployment image.
# Required in production containers. Docker Compose overrides this per service.
# Use "server" for the web app and "worker" for the background workers app.
APP_PROCESS_TYPE=

# Optional image override for docker-compose-prod.yml.
# Set to ghcr.io/<owner>/<repository>:latest when pulling the image built by GitHub Actions.
APP_IMAGE=

SECRET_KEY="super-secret-key"

SITE_URL=http://localhost:8000

# Set to False to pause new account creation while keeping existing logins working.
ALLOW_SIGNUPS=True

POSTGRES_HOST=db
POSTGRES_DB=awesome_repos
POSTGRES_USER=awesome_repos
POSTGRES_PORT=5432
POSTGRES_PASSWORD=awesome_repos
# Optional full Postgres URL override. Fly.io Postgres attaches this as DATABASE_URL.
DATABASE_URL=

REDIS_HOST=redis
REDIS_PASSWORD=awesome_repos
REDIS_PORT=6379
REDIS_DB=0
# Optional full Redis URL override. Leave blank to build it from REDIS_HOST, REDIS_PORT, REDIS_PASSWORD, and REDIS_DB.
REDIS_URL=

# If you want to enable Social Auth via Github
# Get his values after creating a new app on GitHub: https://github.com/settings/applications/new
# For Homepage URL use: http://localhost:8000
# For Authorization callback URL use: http://localhost:8000/accounts/github/login/callback/
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# If you want to load blog post images to S3, instead of local storage
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=awesome_repos
AWS_SECRET_ACCESS_KEY=awesome_repos
AWS_S3_BUCKET_NAME=awesome_repos

# If you need email sending capabilities
# This is not really necessary in the state of the app
# Apart from confirming the email.
# If you don't specify the key you will get the link to confirm email
# in your logs
MAILGUN_API_KEY=
MAILGUN_SENDER_DOMAIN=mg.awesome_repos.app
DEFAULT_FROM_EMAIL=LVTD LLC from Awesome Repos <hello@awesome_repos.app>
SERVER_EMAIL=Awesome Repos Errors <error@awesome_repos.app>







# depending on what AI provider you use, you can set the API key here.
# We are using PydanticAI so use names suggested in their docs:
# https://ai.pydantic.dev/models/
OPENAI_API_KEY=

# Repository semantic search embeddings use PydanticAI against OpenRouter's
# OpenAI-compatible embeddings endpoint.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
REPOSITORY_EMBEDDINGS_ENABLED=True
REPOSITORY_EMBEDDING_MODEL=openai/text-embedding-3-small
REPOSITORY_EMBEDDING_DIMENSIONS=1536
REPOSITORY_EMBEDDING_MAX_CHARS=24000
REPOSITORY_TAGGING_ENABLED=True
REPOSITORY_TAGGING_PROVIDER=openai
REPOSITORY_TAGGING_MODEL_LABEL=fast
REPOSITORY_TAGGING_MAX_CHARS=16000
REPOSITORY_TAGGING_MAX_TAGS=8

LOGFIRE_TOKEN=
LOGFIRE_CONSOLE_SHOW_PROJECT_LINK=False

SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0
SENTRY_ENABLE_LOGS=True
SENTRY_SEND_DEFAULT_PII=False
SENTRY_INCLUDE_LOCAL_VARIABLES=False
SENTRY_MAX_BREADCRUMBS=100
POSTHOG_API_KEY=

# Optional GitHub token for higher API rate limits during awesome-list scanning.
# Use a classic PAT or fine-grained token that can read public repositories.
GITHUB_TOKEN=
GITHUB_REPOSITORY_REFRESH_TARGET_DAYS=14
GITHUB_DAILY_REPOSITORY_REFRESH_LIMIT=1000
GITHUB_DAILY_DISCOVERY_REPOSITORY_LIMIT=250
GITHUB_REPOSITORY_REFRESH_MIN_RATE_LIMIT_REMAINING=1000
